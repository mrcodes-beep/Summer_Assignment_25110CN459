#include <stdio.h>
#include <string.h>

struct Book {
    int id;
    char name[50];
};

int main() {
    struct Book books[100];
    int count = 0, choice, id, i;
    char name[50];

    while (1) {
        printf("\n===== Library Management System =====\n");
        printf("1. Add Book\n");
        printf("2. View Books\n");
        printf("3. Search Book\n");
        printf("4. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Book ID: ");
                scanf("%d", &books[count].id);

                printf("Enter Book Name: ");
                scanf(" %[^\n]", books[count].name);

                count++;
                printf("Book Added Successfully!\n");
                break;

            case 2:
                printf("\nBooks List:\n");
                for (i = 0; i < count; i++) {
                    printf("ID: %d | Name: %s\n",
                           books[i].id, books[i].name);
                }
                break;

            case 3:
                printf("Enter Book ID to Search: ");
                scanf("%d", &id);

                for (i = 0; i < count; i++) {
                    if (books[i].id == id) {
                        printf("Book Found: %s\n", books[i].name);
                        break;
                    }
                }

                if (i == count)
                    printf("Book Not Found!\n");
                break;

            case 4:
                return 0;

            default:
                printf("Invalid Choice!\n");
        }
    }
}